{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "companion-window",
  "description": "Full permissions for the companion app's main settings window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "store:default"
  ]
}
